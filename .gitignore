# tonemirror-server/.gitignore

# Windows 찌꺼기 방어
Thumbs.db
Desktop.ini

# IDE 및 빌드 인프라 격리
.idea/
.vscode/
*.iml
build/
target/
*.jar

# 도커 실물 데이터 무조건 제외 (보안 및 용량 방어)
mysql-data/
static/makeup_outputs/

# 설정 및 환경변수 가드
.env

# 하부 파트 소스코드는 각자의 레포지토리에서 관리하므로 인프라 망에서 전면 제외
tonemirror-python/*
tonemirror-web/*
tonemirror-spring/*
storage/*

# 도커 관련 파일은 server 레포지토리에서 직접 관리하고
# 각각의 레포지토리는 메인 코드에만 집중할 수 있도록 처리
!tonemirror-python/Dockerfile
!tonemirror-spring/Dockerfile
!tonemirror-web/Dockerfile
!tonemirror-python/.dockerignore
!tonemirror-python/requirements.txt